# web/.env.local — copy and fill in
# These are NEXT_PUBLIC_ so they are safe to expose to the browser

NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key

# Your Fly.io API URL after deployment (or localhost for dev)
NEXT_PUBLIC_API_URL=https://raven-api.fly.dev
