# ============================================================
# RAVEN — Environment Variables
# Copy this file to .env and fill in all values.
# NEVER commit .env to git. It is in .gitignore.
# ============================================================

# ── App ──────────────────────────────────────────────────────
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=generate-a-strong-random-key-min-32-chars-here

# ── Supabase ─────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_ANON_KEY=eyJ...your-anon-key
SUPABASE_SERVICE_ROLE_KEY=eyJ...your-service-role-key

# Get this from: Supabase Dashboard → Project Settings → Database → Connection string
# Use the "URI" format, replace [YOUR-PASSWORD] with your DB password
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.YOUR_PROJECT_ID.supabase.co:5432/postgres

# ── Anthropic ────────────────────────────────────────────────
# Get from: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ── Market Data ──────────────────────────────────────────────
# CoinGecko: https://www.coingecko.com/en/api
# Start with Demo key (free), upgrade to Pro ($129/mo) when needed
COINGECKO_API_KEY=CG-...

# NewsAPI: https://newsapi.org
NEWS_API_KEY=...

# Polygon.io (for equities — optional at MVP start)
# POLYGON_API_KEY=...

# ── Storage ──────────────────────────────────────────────────
STORAGE_BUCKET=raven-reports

# ── CORS (add your Vercel URL after deployment) ──────────────
# Comma-separated in production
CORS_ORIGINS=["http://localhost:3000"]

# ── Redis (for Celery task queue) ────────────────────────────
# Local dev: use Redis via Docker (see README)
# Production: Use Upstash Redis (free tier works for MVP)
REDIS_URL=redis://localhost:6379/0

# ── Frontend (.env.local for Next.js) ────────────────────────
# These go in web/.env.local, NOT this file
# NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...your-anon-key
# NEXT_PUBLIC_API_URL=http://localhost:8000
